# ─── SPA fallback ─────────────────────────────────────────────
# Vite outputs a single-page app. Any unknown URL (deep link like
# /contacto, /servicio/01, /trabajo) must serve /index.html so React
# Router can handle the route on the client.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite real files (assets, prerendered pages, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else → SPA entry
  RewriteRule ^ index.html [L]
</IfModule>

# ─── Long-term caching for hashed assets ──────────────────────
# Vite assets in /assets/ have hashes in the filename, so they
# can be cached aggressively. The HTML itself should NOT be cached.

<IfModule mod_expires.c>
  ExpiresActive On

  # Hashed assets (JS, CSS, fonts, images) — 1 year
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css                "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/webp              "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType font/woff               "access plus 1 year"
  ExpiresByType font/woff2              "access plus 1 year"
  ExpiresByType font/ttf                "access plus 1 year"

  # HTML — no cache (so deploys are instant)
  ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

# ─── Gzip / Brotli compression ────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml font/ttf
</IfModule>

# ─── Security headers ─────────────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"

  # HTML must revalidate every visit so deploys are picked up immediately
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ─── PDFs and other docs: inline display ──────────────────────
<FilesMatch "\.pdf$">
  Header set Content-Disposition "inline"
</FilesMatch>

# ─── Block hidden dotfiles (.env, .git, .htaccess) ────────────
# Excluye .well-known/ que Let's Encrypt necesita para validar SSL.
<FilesMatch "^\.(?!well-known)">
  Require all denied
</FilesMatch>
