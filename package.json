{
  "name": "ccgrupo-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:ssr": "set VITE_SSR_DEV=true&& node server.js",
    "build": "vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && tsx scripts/prerender.ts && tsx scripts/clean-build.ts",
    "build:fast": "npm run build -- --mode production",
    "prerender": "tsx scripts/prerender.ts",
    "clean-build": "tsx scripts/clean-build.ts",
    "preview": "vite preview",
    "start:ssr": "node server.js",
    "clean": "rm -rf dist",
    "deploy": "npm run build && git add -f dist && git commit -m \"build: deploy snapshot\" && git push",
    "lint": "tsc --noEmit && eslint src --max-warnings 50",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "convert:logos": "node scripts/convert-client-logos.mjs --delete-src"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@gsap/react": "^2.1.2",
    "@tailwindcss/vite": "^4.1.14",
    "clsx": "^2.1.1",
    "express": "^4.21.2",
    "gsap": "^3.14.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "ogl": "^1.0.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-phone-number-input": "^3.4.16",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.1",
    "autoprefixer": "^10.4.21",
    "eslint": "10.2.0",
    "jsdom": "^29.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "8.58.1",
    "vite": "^6.2.0",
    "vitest": "^4.1.1"
  }
}
